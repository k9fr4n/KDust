# ---- Application gate (mono-user) ----
# Laisser vide pour désactiver la gate (déconseillé même en local).
APP_PASSWORD=change-me

# Clé de chiffrement AES-256-GCM (32 octets base64).
# Générer : openssl rand -base64 32
APP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# Secret pour signer le cookie de session applicative.
# Générer : openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_BASE64_32_BYTES

# ---- Dust / WorkOS (valeurs par défaut surchargeables via /settings) ----
DUST_BASE_URL=https://dust.tt
WORKOS_CLIENT_ID=client_01JGCT55T7FVDG9XF74925R1KT
WORKOS_DOMAIN=api.workos.com
WORKOS_CLAIM_NAMESPACE=https://dust.tt/

# ---- DB / runtime ----
DATABASE_URL=file:/data/kdust.db
NODE_ENV=production
