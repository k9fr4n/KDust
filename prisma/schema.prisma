generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Singleton (id = 1)
model AppConfig {
  id                  Int      @id @default(1)
  dustBaseUrl         String   @default("https://dust.tt")
  workosClientId      String   @default("")
  workosDomain        String   @default("api.workos.com")
  claimNamespace      String   @default("https://dust.tt/")
  defaultTeamsWebhook String?
  updatedAt           DateTime @updatedAt
}

// Singleton Dust session (mono-user)
model DustSession {
  id              Int       @id @default(1)
  accessTokenEnc  String
  refreshTokenEnc String
  workspaceId     String?
  region          String    @default("us-central1")
  expiresAt       DateTime?
  updatedAt       DateTime  @updatedAt
}

model Conversation {
  id                   String     @id @default(cuid())
  dustConversationSId  String?    @unique
  agentSId             String
  agentName            String?
  title                String
  projectName          String?    // nom du projet (tenant) auquel rattacher la conv ; null = global
  pinned               Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  messages             Message[]

  @@index([projectName])
  @@index([pinned])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'agent' | 'system'
  content        String
  attachments    String?      // JSON array
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id             String    @id @default(cuid())
  name           String    @unique  // utilis\u00e9 comme dossier dans /projects
  gitUrl         String               // ex: git@gitlab.ecritel.net:group/repo.git
  branch         String    @default("main")
  lastSyncAt     DateTime?
  lastSyncStatus String?              // 'success' | 'failed'
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CronJob {
  id             String    @id @default(cuid())
  name           String
  schedule       String    // cron expression
  timezone       String    @default("Europe/Paris")
  agentSId       String
  agentName      String?
  prompt         String
  projectPath    String    // chemin relatif dans /projects (ex: "my-app")
  teamsWebhook   String?
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastStatus     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  runs           CronRun[]

  // --- automation push settings ---
  baseBranch         String   @default("main")            // sync & base new branches on this
  branchMode         String   @default("timestamped")     // 'timestamped' | 'stable'
  branchPrefix       String   @default("kdust")           // prefix in generated branch names
  dryRun             Boolean  @default(false)             // agent runs & commits locally, no push
  maxDiffLines       Int      @default(2000)              // abort push if +/- lines exceed
  protectedBranches  String   @default("main,master,develop,production,prod") // csv, never push to these

  // --- advisory cron settings ---
  // kind='automation' (default) = classic git-branch/commit/push pipeline.
  // kind='advice'               = read-only analysis, result parsed as JSON
  //                               and stored in ProjectAdvice; no git writes.
  kind      String   @default("automation")
  // Only meaningful for kind='advice'. One of:
  //   security | performance | code_quality | improvement | documentation
  category  String?
  // Mandatory crons are auto-created with the project and cannot be
  // deleted (the DELETE endpoint returns 403). User can still disable
  // or tweak their schedule/prompt.
  mandatory Boolean  @default(false)
}

// Catalog of advice categories. Each entry is a "template" that gets
// materialized into a CronJob when a project is created (or when an
// admin adds a new template via /settings/advice). Built-in entries
// (builtIn=true) cannot be deleted — only disabled.
model AdviceCategoryDefault {
  id         String   @id @default(cuid())
  key        String   @unique   // slug, ex: 'security', 'code_coverage'
  label      String              // FR display name
  emoji      String   @default("📋")
  prompt     String               // category-specific body; JSON contract appended at build time
  schedule   String               // cron expression (eg. '0 3 * * 1')
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  builtIn    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Latest advice points produced by weekly advisory crons, one row per
// (projectName, category). Overwritten on each successful advice run.
// Displayed in the "Conseils" section of the Projects dashboard.
model ProjectAdvice {
  id          String   @id @default(cuid())
  projectName String
  category    String   // security | performance | code_quality | improvement | documentation
  // JSON-encoded array of { title, description, severity, refs? }.
  // Parsing is deferred to the read path so a malformed response in
  // rawOutput doesn't kill the row — see cron runner advice parser.
  points      String
  // Overall category score in [0..100]. The agent grades the whole
  // category (not a single point); we parse it from the same JSON
  // block. Null when the agent didn't provide one (legacy rows or
  // parser failure on the score field alone).
  score       Int?
  rawOutput   String?  // full agent text, for debugging / copy-paste
  cronJobId   String?  // link back to the job that produced this
  cronRunId   String?  // link back to the exact run (nullable: manual re-runs)
  generatedAt DateTime @default(now())

  @@unique([projectName, category])
  @@index([projectName])
}

model CronRun {
  id         String    @id @default(cuid())
  cronJobId  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    // 'running' | 'success' | 'no-op' | 'skipped' | 'aborted' | 'failed'
  output     String?
  error      String?
  cronJob    CronJob   @relation(fields: [cronJobId], references: [id], onDelete: Cascade)

  // --- push metadata ---
  branch        String?
  baseBranch    String?
  commitSha     String?
  filesChanged  Int?
  linesAdded    Int?
  linesRemoved  Int?
  dryRun        Boolean  @default(false)

  // --- live progress ---
  phase         String?  // 'queued'|'syncing'|'branching'|'mcp'|'agent'|'diff'|'committing'|'pushing'|'done'
  phaseMessage  String?  // short human-readable status line

  @@index([cronJobId])
}
