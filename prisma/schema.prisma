generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Singleton (id = 1)
model AppConfig {
  id                  Int      @id @default(1)
  dustBaseUrl         String   @default("https://dust.tt")
  workosClientId      String   @default("")
  workosDomain        String   @default("api.workos.com")
  claimNamespace      String   @default("https://dust.tt/")
  defaultTeamsWebhook String?
  // Default Telegram chat_id for run-completion notifications
  // (Franck 2026-04-25 18:14). Used when Task.telegramChatId is
  // null. The bot token itself is held in env.KDUST_TELEGRAM_BOT_TOKEN
  // (it's a credential, not config). Stored as String because
  // chat_ids can be negative for groups/channels and exceed
  // Int32 range (e.g. supergroups -100xxxxxxxxxxx).
  defaultTelegramChatId String?

  // Global wall-clock runtime caps (Franck 2026-04-23 09:56).
  // Applied when Task.maxRuntimeMs is null. Clamp [30s, 6h] still
  // enforced in runner.ts — out-of-range values fall back to the
  // schema defaults below. Stored in ms for parity with task rows.
  leafRunTimeoutMs         Int @default(1800000)   // 30 min
  orchestratorRunTimeoutMs Int @default(3600000)   // 60 min

  // Default timezone for schedules and human-facing timestamps
  // (Franck 2026-04-24 17:07). IANA name (e.g. "Europe/Paris",
  // "America/New_York", "Asia/Tokyo"). Per-task Task.timezone
  // still wins when set; this is the fallback used by scheduler
  // and Dust chat user-context.
  timezone            String   @default("Europe/Paris")

  updatedAt           DateTime @updatedAt
}

// Singleton Dust session (mono-user)
model DustSession {
  id              Int       @id @default(1)
  accessTokenEnc  String
  refreshTokenEnc String
  workspaceId     String?
  region          String    @default("us-central1")
  expiresAt       DateTime?
  updatedAt       DateTime  @updatedAt
}

model Conversation {
  id                   String     @id @default(cuid())
  dustConversationSId  String?    @unique
  agentSId             String
  agentName            String?
  title                String
  projectName          String?    // nom du projet (tenant) auquel rattacher la conv ; null = global
  pinned               Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  messages             Message[]

  @@index([projectName])
  @@index([pinned])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'agent' | 'system'
  content        String
  attachments    String?      // JSON array
  createdAt      DateTime     @default(now())

  // --- v4: Dust stream instrumentation ---
  // Captured from the SSE event loop in src/lib/dust/chat.ts at
  // agent_message_success. Populated only for role='agent' messages;
  // user messages leave these at their defaults (null / 0).
  //
  // streamStats is the raw per-event-type count Map serialised as
  // JSON, e.g. {"generation_tokens":47,"tool_call_started":17,...}.
  // Kept as a blob (not a separate table) so the schema can evolve
  // as Dust adds/renames events without a migration.
  streamStats    String?
  // Cheap pre-aggregated counters used by /settings/usage for SUM
  // queries without JSON parsing.
  toolCalls      Int          @default(0)    // # of tool_call_started
  // Distinct tool names invoked during this turn, JSON array of strings
  // (e.g. ["fs.read","bash","fsWrite"]). Empty array when no tools.
  toolNames      String       @default("[]")
  // Wall-clock duration of the stream loop, milliseconds. Null for
  // legacy rows and when the stream was aborted.
  durationMs     Int?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id             String    @id @default(cuid())
  name           String    @unique  // utilise comme dossier dans /projects
  // gitUrl optional since 2026-04-19 (Franck): projects can exist
  // without a git remote. When null, sync + push are skipped;
  // the local dir is still provisioned.
  gitUrl         String?
  branch         String    @default("main")
  // Free-form human description shown on dashboards.
  description    String?
  // Default Dust agent for this project (Franck 2026-04-19 19:04).
  // Null = no preset, user picks per task/chat. Populated either
  // by picking an existing agent ("Pick") or by creating a new
  // one via Dust API ("Create"). We store only the sId; name and
  // other fields are resolved on demand via GET /api/agents to
  // keep KDust in sync with upstream edits in Dust.
  defaultAgentSId  String?

  // --- Branch policy (Phase 1, Franck 2026-04-19 22:32) ---
  // Source-of-truth for branch management on this project. Task
  // rows can still override these individually (nullable columns
  // on Task), but when null they inherit from here. Keeps all 20
  // tasks of a project consistent without per-task duplication.
  //
  // defaultBaseBranch : git branch on which sync happens and new
  //                     KDust branches are forked.
  // branchPrefix      : enforced prefix \u2014 lets the cleanup / PR
  //                     logic unambiguously recognise KDust branches.
  // protectedBranches : CSV, never push to these. Evaluated both
  //                     against the resolved branch name AND against
  //                     defaultBaseBranch itself.
  defaultBaseBranch  String   @default("main")
  branchPrefix       String   @default("kdust")
  protectedBranches  String   @default("main,master,develop,production,prod")

  // --- Git platform integration (Phase 2, Franck 2026-04-19 22:49) ---
  // 'github' | 'gitlab' | 'none'. NULL means "auto-detect from gitUrl
  // at call time" \u2014 UX: zero-config happy path on github.com.
  platform           String?
  // REST API root. Defaults per platform:
  //   github \u2192 https://api.github.com
  //   gitlab \u2192 https://<host>/api/v4 (derived from gitUrl host)
  platformApiUrl     String?
  // NAME of an environment variable containing the PAT / token. The
  // raw token itself is NEVER stored in the DB. Runtime resolves via
  // process.env[platformTokenRef]. Missing env = autoOpenPR skipped
  // with a warning in TaskRun.output so the pipeline doesn\u0027t break.
  platformTokenRef   String?
  // 'owner/repo' (GitHub) or 'group/subgroup/repo' (GitLab). NULL
  // \u2192 parse from gitUrl.
  remoteProjectRef   String?
  // Master switch: open a draft PR/MR after every successful push.
  autoOpenPR         Boolean  @default(false)
  // Override branch to target; NULL \u2192 defaultBaseBranch.
  prTargetBranch     String?
  // CSV of GitHub usernames / GitLab user IDs to request review from.
  prRequiredReviewers String?
  // CSV of labels to apply to the new PR/MR.
  prLabels           String   @default("kdust,automation")

  lastSyncAt     DateTime?
  lastSyncStatus String?              // 'success' | 'failed'
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// "Task" is the v2 name for what used to be CronJob. Tasks are
// manually triggered from the UI ("Run now") — KDust no longer runs a
// scheduler. The underlying SQL table is kept as `CronJob` via
// @@map so no migration / data loss is required when upgrading.
// `schedule` and `timezone` columns are also kept for backwards
// compatibility but are NEVER consulted at runtime.
model Task {
  id             String    @id @default(cuid())
  name           String
  // Legacy columns — kept in DB, ignored by the runner.
  schedule       String    @default("manual")
  timezone       String    @default("Europe/Paris")
  agentSId       String
  agentName      String?
  prompt         String
  // chemin relatif dans /projects (ex: "my-app").
  //
  // NULLABLE (Franck 2026-04-22): a task with projectPath=null is a
  // "generic" / "template" task, not bound to a specific project.
  // It can only be invoked via the task-runner MCP tool `run_task`
  // with a `project` argument, which supplies the project context
  // for the run (MCP chroot, registry lookup, {{PROJECT}} substitution
  // in the prompt). Generic tasks MUST have:
  //   - schedule = 'manual'          (no cron: scheduler has no project context)
  //   - pushEnabled = false          (no git pipeline without a project)
  //   - taskRunnerEnabled = false    (generics are leaves, not orchestrators)
  //   - mandatory = false            (not auto-created with a project)
  // These invariants are enforced at create/patch time in /api/tasks.
  projectPath    String?
  teamsWebhook   String?
  // Per-task Telegram chat_id override. Falls back to
  // AppConfig.defaultTelegramChatId, then no-op if both null
  // OR env.KDUST_TELEGRAM_BOT_TOKEN is missing. Same string-not-int
  // rationale as the AppConfig field.
  telegramChatId String?
  // Notification kill-switches per transport (Franck 2026-04-25
  // 18:50). Independent of the chat_id / webhook resolution: a
  // task can have a resolved Telegram chat_id (via global default)
  // but be opted out of Telegram pings via telegramNotifyEnabled=
  // false. Default true so adding a global default Telegram /
  // Teams target retroactively turns notifications ON for all
  // existing tasks (the expected UX for "I just added a default,
  // start notifying").
  teamsNotifyEnabled    Boolean @default(true)
  telegramNotifyEnabled Boolean @default(true)
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastStatus     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  runs           TaskRun[]

  // --- automation push settings ---
  // Master switch for the whole post-agent git pipeline. When false,
  // the runner executes the prompt only: no branch, no commit, no
  // push, and the prompt is sent as-is (no KDust automation context
  // footer appended). Useful for chat-style recurring tasks that the
  // user just wants to fire on a cron without mutating the repo.
  pushEnabled        Boolean  @default(true)
  // --- Branch overrides (Phase 1, 2026-04-19).
  // NULL = inherit from the parent Project. Resolved via
  // src/lib/branch-policy.ts before the runner reads them.
  baseBranch         String?
  branchPrefix       String?
  protectedBranches  String?
  // Stays per-task: mode is inherently task-specific, not project-wide.
  branchMode         String   @default("timestamped")
  dryRun             Boolean  @default(false)
  maxDiffLines       Int      @default(2000)

  // Mandatory tasks are auto-created with the project and cannot be
  // deleted (the DELETE endpoint returns 403).
  mandatory Boolean  @default(false)

  // --- Task orchestration (Franck 2026-04-20 22:58) ---
  // When true, the agent running this task gets access to the
  // `task-runner` MCP server, exposing the single tool `run_task`
  // so it can invoke other tasks of the same project sequentially.
  // Opt-in per task (not per project) to avoid accidental recursion:
  // only an explicitly-designated "orchestrator" task should have
  // this. Children (codegen/lint/test) must leave it false.
  taskRunnerEnabled Boolean @default(false)

  // --- Wall-clock runtime cap (Franck 2026-04-23 00:23) ---
  // Per-task override for the runner's hard kill-timer. When null,
  // the runner falls back to env defaults:
  //   - KDUST_ORCHESTRATOR_TIMEOUT_MS (default 3_600_000 = 1h)
  //     used when taskRunnerEnabled=true
  //   - KDUST_RUN_TIMEOUT_MS          (default 1_800_000 = 30min)
  //     used for leaf tasks
  // The legacy hardcoded 10-minute cap is gone; orchestrators that
  // fan out to long-running children would hit it prematurely.
  //
  // Set this only when a task needs a tighter OR looser bound than
  // the project-wide default. Measured in milliseconds; safety
  // clamp applied in runner.ts: values <30s or >6h are ignored.
  maxRuntimeMs Int?

  // --- Command runner (Franck 2026-04-21 13:39) ---
  // When true, the agent running this task gets access to the
  // `command-runner` MCP server exposing `run_command`. Unlike the
  // fs-cli's own run_command (Dust-hosted, which is unreliable and
  // unobservable), our server-side implementation:
  //   - logs every invocation in the `Command` table below
  //     (forensic trail, replayable in the UI)
  //   - enforces a configurable denylist of dangerous args
  //   - runs with a chroot to the project working tree
  //   - has its transport owned by KDust, no Dust-side re-init noise
  // Opt-in per task, always safe default (false).
  commandRunnerEnabled Boolean @default(false)

  // --- Secret env bindings (Franck 2026-04-21 21:30) ---
  // Per-task mapping "env var name -> global secret name". When the
  // command-runner MCP spawns a child process for this task, it
  // resolves each binding server-side and injects the decrypted value
  // into the child env BEFORE exec. The LLM never sees the value and
  // never references it in its argv \u2014 from the model\u0027s point of
  // view, `$GITHUB_TOKEN` (or whatever env name was chosen) is just
  // already set in the shell it calls `gh release create` from.
  // No auto-propagation to child tasks spawned via task-runner.
  secretBindings TaskSecret[]

  @@map("CronJob")
}

// Renamed CronRun -> TaskRun in v2. Underlying SQL table kept as
// `CronRun` via @@map; FK column kept as `cronJobId` via @map.
model TaskRun {
  id         String    @id @default(cuid())
  taskId     String    @map("cronJobId")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    // 'running' | 'success' | 'no-op' | 'skipped' | 'aborted' | 'failed'
  output     String?
  // Chain-of-thought / reasoning stream (Franck 2026-04-24 18:51).
  // Dust streams reasoning tokens as generation_tokens events with
  // classification='chain_of_thought'; previously dropped on the
  // floor, now persisted so the run detail page can surface the
  // agent's hidden thinking in a collapsible section.
  thinkingOutput String?
  error     String?
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // --- push metadata ---
  branch        String?
  baseBranch    String?
  commitSha     String?

  // --- B2/B3 orchestrator ↔ child plumbing (Franck 2026-04-24 20:47) ---
  // baseBranchSource identifies WHERE the effective baseBranch for
  // this run came from:
  //   - 'default'      : resolveBranchPolicy (task+project), no override
  //   - 'explicit'     : caller passed base_branch on run_task/dispatch_task
  //   - 'auto-inherit' : B2 auto-inherit kicked in because parentRun
  //                      had a non-default branch
  // Surfaced on /runs/:id as a small pill next to the base branch
  // name so operators can tell at a glance whether a run inherited
  // from its parent or not.
  baseBranchSource String?
  // mergeBackStatus traces the auto-merge back into the parent's
  // branch attempted by B3 at the end of a successful run_task
  // dispatch. One of:
  //   NULL             : not a child run, or B3 disabled by the caller
  //   'skipped'        : child made no commits (nothing to merge)
  //   'ff'             : fast-forward merge succeeded + pushed
  //   'refused'        : non-linear history, merge refused
  //   'failed'         : merge/push errored (see mergeBackDetails)
  mergeBackStatus  String?
  mergeBackDetails String?
  filesChanged  Int?
  linesAdded    Int?
  linesRemoved  Int?
  dryRun        Boolean  @default(false)

  // Starred run (Franck 2026-04-20 18:04). Mirrors the `pinned` flag
  // on Conversation. Set via POST /api/runs/:id/pin, surfaced in
  // the RunCard UI; pinned runs float to the top of the list.
  pinned        Boolean  @default(false)

  // --- live progress ---
  phase         String?  // 'queued'|'syncing'|'branching'|'mcp'|'agent'|'diff'|'committing'|'pushing'|'done'
  phaseMessage  String?  // short human-readable status line

  // Dust conversation sId produced by this run, if any. Stored as a
  // soft reference (no FK) because the conversation lives in the
  // Conversation table (keyed by dustConversationSId @unique). UI
  // resolves it at display time to build a link to /conversations/:id.
  // Kept nullable: early-failing runs (sync/branching phase) never
  // reach the Dust call and legitimately have no conversation.
  dustConversationSId String?

  // --- Git platform artefacts (Phase 2, Franck 2026-04-19 22:49) ---
  // Populated when the owning Project has autoOpenPR=true and the
  // push phase succeeded. NULL for runs that didn\u0027t open a PR
  // (autoOpenPR off, dryRun, push skipped, audit kind, \u2026).
  prUrl         String?
  prNumber      Int?
  // 'draft' | 'open' | 'merged' | 'closed' | 'failed'. 'failed' is
  // KDust-internal: the PR API call itself errored (rate-limit, 404,
  // auth) \u2014 the branch is pushed, but no PR exists upstream.
  prState       String?

  // --- Provenance (Franck 2026-04-22 20:34) ---
  // Who/what triggered this run. A small enum-as-string rather than
  // a Prisma enum so adding new triggers (webhook, API, …) is a
  // pure data change.
  //
  //   'cron'    : fired by the internal scheduler at schedule match
  //   'manual'  : a human clicked Run in the UI or POSTed
  //               /api/tasks/:id/run; triggeredBy holds the actor
  //               identity when available (email / session user id)
  //   'mcp'     : spawned by another run via the task-runner MCP
  //               tool (run_task / wait_for_run); triggeredBy holds
  //               the parent task name for quick display, and the
  //               full chain remains walkable via parentRunId.
  //
  // NULL trigger is only possible on rows predating this column
  // (pre-nuke legacy) — the UI falls back to "unknown".
  trigger       String?
  triggeredBy   String?

  // --- Task-runner lineage (Franck 2026-04-20 22:58) ---
  // When this run was spawned by another run via the task-runner
  // MCP tool, parentRunId points to that parent run. NULL for
  // top-level runs (manual "Run now" or cron). runDepth = 0 for
  // top-level, parent.runDepth + 1 for children.
  //
  // Used for:
  //   - arborescence UI (parent \u2192 children timeline)
  //   - runaway-recursion guard (KDUST_MAX_RUN_DEPTH, default 10)
  //   - cancel-cascade (aborting a parent aborts its sub-tree)
  //   - concurrency-lock bypass: when the only "concurrent" run on
  //     the same projectPath is an ancestor of this run, the
  //     orchestrator is paused-waiting, so the child can legitimately
  //     take over the working tree (see runTask concurrency check).
  //
  // onDelete: SetNull keeps orphan children visible in the UI if the
  // parent is manually deleted; we never want a cascade here.
  parentRunId   String?
  runDepth      Int      @default(0)
  parentRun     TaskRun?  @relation("TaskRunTree", fields: [parentRunId], references: [id], onDelete: SetNull)
  childRuns     TaskRun[] @relation("TaskRunTree")

  @@index([taskId])
  @@index([dustConversationSId])
  @@index([parentRunId])
  @@map("CronRun")

  commands Command[]
}

// One row per `run_command` invocation executed through the KDust-side
// command-runner MCP server (Franck 2026-04-21 13:39). Backs the
// "Commands executed" section of /runs/[id], the audit log, and the
// (future) replay/retry flows.
//
// stdout/stderr are stored inline with a hard cap (truncMarker + tail
// when oversized) so a single rogue command can't blow the DB up.
// If we ever need full output for large builds, we'll migrate to
// filesystem refs (stdoutRef/stderrRef pointing to /data/logs/...)
// at that point \u2014 the schema leaves room for that evolution since
// both columns are nullable.
model Command {
  id           String    @id @default(cuid())
  runId        String
  command      String     // "docker", "npm", "git", \u2026
  args         String     // JSON array of string args
  cwd          String?
  exitCode     Int?       // null while running or if the process crashed before exiting
  stdout       String?    // capped; truncated tail when very long
  stderr       String?    // capped; truncated tail when very long
  stdoutBytes  Int?       // true pre-truncation size (for UI "cut off at X")
  stderrBytes  Int?
  durationMs   Int?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  // 'running' | 'success' | 'failed' | 'timeout' | 'killed' | 'denied'
  //   - denied: rejected by the args denylist before spawning
  //   - killed: KDust aborted the process (cancel cascade, TTL)
  //   - timeout: exceeded the per-call timeoutMs
  status       String    @default("running")
  errorMessage String?

  run TaskRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Secret manager (Franck 2026-04-21 21:30)
// ---------------------------------------------------------------------------
// Global, scoped-to-KDust secrets referenced by tasks through the
// TaskSecret binding below. `valueEnc` is AES-256-GCM encrypted using
// APP_ENCRYPTION_KEY (same KDF as DustSession.refreshTokenEnc) so a
// DB dump alone is useless without the env var.
//
// Design constraints deliberately applied (threat model in
// docs/secrets.md):
//   1. No LLM-accessible path returns the plaintext. Only the
//      command-runner child-process spawn reads it via resolve()
//      below, server-side, immediately before exec().
//   2. No versioning / no "rotation" flow. Updates are in-place;
//      any run in flight keeps its already-resolved env.
//   3. Plaintext never appears in logs, stdout relayed to the LLM,
//      or in audit rows — see the redactor in command-runner.
//
// The table is voluntarily shallow: a future enhancement could push
// to Azure Key Vault / Vault via a pluggable backend, but the first
// version stores encrypted-at-rest locally in SQLite.
model Secret {
  id          Int      @id @default(autoincrement())
  // Lowercase slug identifier, unique. Used by tasks to reference
  // the secret (`{taskId, envName -> secretName}`). Keeping it
  // URL-safe and shell-safe is enforced at the API layer.
  name        String   @unique
  // AES-256-GCM ciphertext; decoded only by the command-runner at
  // exec time. Never returned by any read API.
  valueEnc    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Bumped by command-runner on every successful decrypt-and-inject.
  // Lets the UI show "never used" vs "used 2h ago" to flag stale
  // secrets at audit time.
  lastUsedAt  DateTime?

  bindings    TaskSecret[]
}

// Per-task env-var -> secret binding. Unique on (taskId, envName)
// so each env var has a single source of truth within a task, and
// indexed on secretName to make "which tasks reference this secret?"
// O(1) when planning a rotation.
//
// onDelete behavior:
//   - Task: Cascade (dropping a task drops its bindings)
//   - Secret: Restrict — you can't delete a Secret that's still
//     bound somewhere; the UI must first unbind or the user must
//     pass ?force=true which drops the bindings first.
model TaskSecret {
  id         Int    @id @default(autoincrement())
  taskId     String
  envName    String
  secretName String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  secret Secret @relation(fields: [secretName], references: [name], onDelete: Restrict)

  @@unique([taskId, envName])
  @@index([secretName])
}
