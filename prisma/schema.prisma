generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Singleton (id = 1)
model AppConfig {
  id                  Int      @id @default(1)
  dustBaseUrl         String   @default("https://dust.tt")
  workosClientId      String   @default("")
  workosDomain        String   @default("api.workos.com")
  claimNamespace      String   @default("https://dust.tt/")
  defaultTeamsWebhook String?
  updatedAt           DateTime @updatedAt
}

// Singleton Dust session (mono-user)
model DustSession {
  id              Int       @id @default(1)
  accessTokenEnc  String
  refreshTokenEnc String
  workspaceId     String?
  region          String    @default("us-central1")
  expiresAt       DateTime?
  updatedAt       DateTime  @updatedAt
}

model Conversation {
  id                   String     @id @default(cuid())
  dustConversationSId  String?    @unique
  agentSId             String
  agentName            String?
  title                String
  projectName          String?    // nom du projet (tenant) auquel rattacher la conv ; null = global
  pinned               Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  messages             Message[]

  @@index([projectName])
  @@index([pinned])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'agent' | 'system'
  content        String
  attachments    String?      // JSON array
  createdAt      DateTime     @default(now())

  // --- v4: Dust stream instrumentation ---
  // Captured from the SSE event loop in src/lib/dust/chat.ts at
  // agent_message_success. Populated only for role='agent' messages;
  // user messages leave these at their defaults (null / 0).
  //
  // streamStats is the raw per-event-type count Map serialised as
  // JSON, e.g. {"generation_tokens":47,"tool_call_started":17,...}.
  // Kept as a blob (not a separate table) so the schema can evolve
  // as Dust adds/renames events without a migration.
  streamStats    String?
  // Cheap pre-aggregated counters used by /settings/usage for SUM
  // queries without JSON parsing.
  toolCalls      Int          @default(0)    // # of tool_call_started
  // Distinct tool names invoked during this turn, JSON array of strings
  // (e.g. ["fs.read","bash","fsWrite"]). Empty array when no tools.
  toolNames      String       @default("[]")
  // Wall-clock duration of the stream loop, milliseconds. Null for
  // legacy rows and when the stream was aborted.
  durationMs     Int?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id             String    @id @default(cuid())
  name           String    @unique  // utilise comme dossier dans /projects
  // gitUrl optional since 2026-04-19 (Franck): projects can exist
  // without a git remote. When null, sync + push are skipped;
  // the local dir is still provisioned.
  gitUrl         String?
  branch         String    @default("main")
  // Free-form human description shown on dashboards.
  description    String?
  // Default Dust agent for this project (Franck 2026-04-19 19:04).
  // Null = no preset, user picks per task/chat. Populated either
  // by picking an existing agent ("Pick") or by creating a new
  // one via Dust API ("Create"). We store only the sId; name and
  // other fields are resolved on demand via GET /api/agents to
  // keep KDust in sync with upstream edits in Dust.
  defaultAgentSId  String?
  lastSyncAt     DateTime?
  lastSyncStatus String?              // 'success' | 'failed'
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// "Task" is the v2 name for what used to be CronJob. Tasks are
// manually triggered from the UI ("Run now") — KDust no longer runs a
// scheduler. The underlying SQL table is kept as `CronJob` via
// @@map so no migration / data loss is required when upgrading.
// `schedule` and `timezone` columns are also kept for backwards
// compatibility but are NEVER consulted at runtime.
model Task {
  id             String    @id @default(cuid())
  name           String
  // Legacy columns — kept in DB, ignored by the runner.
  schedule       String    @default("manual")
  timezone       String    @default("Europe/Paris")
  agentSId       String
  agentName      String?
  prompt         String
  projectPath    String    // chemin relatif dans /projects (ex: "my-app")
  teamsWebhook   String?
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastStatus     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  runs           TaskRun[]

  // --- automation push settings ---
  // Master switch for the whole post-agent git pipeline. When false,
  // the runner executes the prompt only: no branch, no commit, no
  // push, and the prompt is sent as-is (no KDust automation context
  // footer appended). Useful for chat-style recurring tasks that the
  // user just wants to fire on a cron without mutating the repo.
  pushEnabled        Boolean  @default(true)
  baseBranch         String   @default("main")            // sync & base new branches on this
  branchMode         String   @default("timestamped")     // 'timestamped' | 'stable'
  branchPrefix       String   @default("kdust")           // prefix in generated branch names
  dryRun             Boolean  @default(false)             // agent runs & commits locally, no push
  maxDiffLines       Int      @default(2000)              // abort push if +/- lines exceed
  protectedBranches  String   @default("main,master,develop,production,prod") // csv, never push to these

  // --- advisory task settings ---
  // kind='automation' (default) = classic git-branch/commit/push pipeline.
  // kind='audit'               = read-only analysis, result parsed as JSON
  //                               and stored in ProjectAudit; no git writes.
  kind      String   @default("automation")
  // Only meaningful for kind='audit'. One of:
  //   security | performance | code_quality | improvement | documentation
  category  String?
  // Mandatory tasks are auto-created with the project and cannot be
  // deleted (the DELETE endpoint returns 403).
  mandatory Boolean  @default(false)

  @@map("CronJob")
}

// Catalog of audit categories. Each entry is a "template" that gets
// materialized into a CronJob when a project is created (or when an
// admin adds a new template via /settings/audits). Built-in entries
// (builtIn=true) cannot be deleted — only disabled.
model AuditCategoryDefault {
  id         String   @id @default(cuid())
  key        String   @unique   // slug, ex: 'security', 'code_coverage'
  label      String              // FR display name
  emoji      String   @default("📋")
  prompt     String               // category-specific body; JSON contract appended at build time
  schedule   String               // cron expression (eg. '0 3 * * 1')
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  builtIn    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Renamed AdviceCategoryDefault -> AuditCategoryDefault in v5
  // (Audit rebrand). Underlying SQL table kept as `AdviceCategoryDefault`
  // via @@map to avoid a disruptive data migration \u2014 only the Prisma
  // Client accessor name changes (db.auditCategoryDefault.*).
  @@map("AdviceCategoryDefault")
}

// Latest audit points produced by weekly audit crons, one row per
// (projectName, category). Overwritten on each successful audit run.
// Displayed in the "Audits" section of the Projects dashboard.
model ProjectAudit {
  id          String   @id @default(cuid())
  projectName String
  category    String   // security | performance | code_quality | improvement | documentation
  // JSON-encoded array of { title, description, severity, refs? }.
  // Parsing is deferred to the read path so a malformed response in
  // rawOutput doesn't kill the row — see cron runner audit parser.
  points      String
  // Overall category score in [0..100]. The agent grades the whole
  // category (not a single point); we parse it from the same JSON
  // block. Null when the agent didn't provide one (legacy rows or
  // parser failure on the score field alone).
  score       Int?
  rawOutput   String?  // full agent text, for debugging / copy-paste
  taskId      String?  @map("cronJobId")  // link back to the task that produced this
  taskRunId   String?  @map("cronRunId")  // link back to the exact run (nullable: manual re-runs)
  generatedAt DateTime @default(now())

  @@unique([projectName, category])
  @@index([projectName])
  // Renamed ProjectAdvice -> ProjectAudit in v5 (Audit rebrand).
  // Underlying SQL table kept as `ProjectAdvice` via @@map to avoid a
  // disruptive data migration \u2014 only the Prisma Client accessor
  // name changes (db.projectAudit.*).
  @@map("ProjectAdvice")
}

// Renamed CronRun -> TaskRun in v2. Underlying SQL table kept as
// `CronRun` via @@map; FK column kept as `cronJobId` via @map.
model TaskRun {
  id         String    @id @default(cuid())
  taskId     String    @map("cronJobId")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    // 'running' | 'success' | 'no-op' | 'skipped' | 'aborted' | 'failed'
  output     String?
  error      String?
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // --- push metadata ---
  branch        String?
  baseBranch    String?
  commitSha     String?
  filesChanged  Int?
  linesAdded    Int?
  linesRemoved  Int?
  dryRun        Boolean  @default(false)

  // --- live progress ---
  phase         String?  // 'queued'|'syncing'|'branching'|'mcp'|'agent'|'diff'|'committing'|'pushing'|'done'
  phaseMessage  String?  // short human-readable status line

  // Dust conversation sId produced by this run, if any. Stored as a
  // soft reference (no FK) because the conversation lives in the
  // Conversation table (keyed by dustConversationSId @unique). UI
  // resolves it at display time to build a link to /conversations/:id.
  // Kept nullable: early-failing runs (sync/branching phase) never
  // reach the Dust call and legitimately have no conversation.
  dustConversationSId String?

  @@index([taskId])
  @@index([dustConversationSId])
  @@map("CronRun")
}
