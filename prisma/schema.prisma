generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Singleton (id = 1)
model AppConfig {
  id                  Int      @id @default(1)
  dustBaseUrl         String   @default("https://dust.tt")
  workosClientId      String   @default("")
  workosDomain        String   @default("api.workos.com")
  claimNamespace      String   @default("https://dust.tt/")
  defaultTeamsWebhook String?
  updatedAt           DateTime @updatedAt
}

// Singleton Dust session (mono-user)
model DustSession {
  id              Int       @id @default(1)
  accessTokenEnc  String
  refreshTokenEnc String
  workspaceId     String?
  region          String    @default("us-central1")
  expiresAt       DateTime?
  updatedAt       DateTime  @updatedAt
}

model Conversation {
  id                   String     @id @default(cuid())
  dustConversationSId  String?    @unique
  agentSId             String
  agentName            String?
  title                String
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  messages             Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'agent' | 'system'
  content        String
  attachments    String?      // JSON array
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id             String    @id @default(cuid())
  name           String    @unique  // utilis\u00e9 comme dossier dans /projects
  gitUrl         String               // ex: git@gitlab.ecritel.net:group/repo.git
  branch         String    @default("main")
  lastSyncAt     DateTime?
  lastSyncStatus String?              // 'success' | 'failed'
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CronJob {
  id             String    @id @default(cuid())
  name           String
  schedule       String    // cron expression
  timezone       String    @default("Europe/Paris")
  agentSId       String
  agentName      String?
  prompt         String
  projectPath    String    // chemin relatif dans /projects (ex: "my-app")
  teamsWebhook   String?
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastStatus     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  runs           CronRun[]
}

model CronRun {
  id         String    @id @default(cuid())
  cronJobId  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    // 'running' | 'success' | 'failed'
  output     String?
  error      String?
  cronJob    CronJob   @relation(fields: [cronJobId], references: [id], onDelete: Cascade)

  @@index([cronJobId])
}
