#!/usr/bin/env bash
# audit-iac <project>
set -euo pipefail
. "$(dirname "$(readlink -f "$0")")/../lib/common.sh"
PROJECT="${1:?Usage: audit-iac <project>}"
kdust::require_project "$PROJECT"
SRC_DIR=$(kdust::project_path "$PROJECT")
ENABLED=$(kdust::lookup "$PROJECT" '.audit.iac')
[ "$ENABLED" != "true" ] && { kdust::warn "audit.iac disabled for $PROJECT"; exit 0; }
export PROJECT SRC_DIR
exec "$(dirname "$(readlink -f "$0")")/../lib/drivers/checkov.sh"
