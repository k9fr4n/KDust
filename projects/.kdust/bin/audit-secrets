#!/usr/bin/env bash
# audit-secrets <project>
set -euo pipefail
. "$(dirname "$(readlink -f "$0")")/../lib/common.sh"
PROJECT="${1:?Usage: audit-secrets <project>}"
kdust::require_project "$PROJECT"
SRC_DIR=$(kdust::project_path "$PROJECT")
ENABLED=$(kdust::lookup "$PROJECT" '.audit.secrets')
[ "$ENABLED" != "true" ] && { kdust::warn "audit.secrets disabled for $PROJECT"; exit 0; }
export PROJECT SRC_DIR
exec "$(dirname "$(readlink -f "$0")")/../lib/drivers/gitleaks.sh"
