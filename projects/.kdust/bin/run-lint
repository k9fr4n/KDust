#!/usr/bin/env bash
# =============================================================================
# run-lint <project>
# =============================================================================
set -euo pipefail
. "$(dirname "$(readlink -f "$0")")/../lib/common.sh"

PROJECT="${1:?Usage: run-lint <project>}"
kdust::require_project "$PROJECT"

TOOL=$(kdust::lookup "$PROJECT" '.lint.tool')
SRC_DIR=$(kdust::project_path "$PROJECT")
[ -z "$TOOL" ] && { kdust::critical "No lint.tool for $PROJECT"; exit 2; }

export PROJECT SRC_DIR FIX=0
DRIVERS_DIR="$(dirname "$(readlink -f "$0")")/../lib/drivers"

case "$TOOL" in
  psscriptanalyzer)  exec "$DRIVERS_DIR/psscriptanalyzer.sh" ;;
  tflint)            exec "$DRIVERS_DIR/tflint.sh" ;;
  shellcheck)        exec "$DRIVERS_DIR/shellcheck.sh" ;;
  golangci-lint)     exec "$DRIVERS_DIR/golangci-lint.sh" ;;
  *) kdust::critical "Unknown lint.tool: $TOOL"; exit 3 ;;
esac
